# Flask runtime
DEBUG=false
PORT=5000
SECRET_KEY=change-this-long-secret
PUBLIC_BASE_URL=https://api.example.com

# CORS (comma separated)
CORS_ORIGINS=https://your-frontend-domain.vercel.app

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# MySQL connection
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-db-password
MYSQL_DB=alumniconnect

# Railway-friendly options (use either MYSQL_URL/DATABASE_URL OR host/user/password vars above)
# MYSQL_URL=mysql://user:password@host:3306/database
# DATABASE_URL=mysql://user:password@host:3306/database

# Set false if you do not want schema.sql auto-run during app startup
AUTO_INIT_DB=true

# SMTP email provider (required for Email Center + auto notices)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=AlumniConnect Admin

# Mail provider: auto | smtp | brevo
# auto uses Brevo API when BREVO_API_KEY is set; otherwise SMTP.
MAIL_PROVIDER=auto
BREVO_API_KEY=
# Optional override (default shown):
# BREVO_API_URL=https://api.brevo.com/v3/smtp/email
# BREVO_TIMEOUT=20
