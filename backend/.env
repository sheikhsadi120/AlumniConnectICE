# MySQL connection (3 options)
# Option 1 (local root, empty password):
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=alumniconnect
MYSQL_SSL_MODE=disable
#
# Option 2 (local root, with password):
# MYSQL_USER=root
# MYSQL_PASSWORD=root
#
# Option 3 (Aiven MySQL - removed):
# The Aiven-specific credentials were removed to clean deployment-related secrets.
# If you need a managed DB later, re-populate these variables appropriately.
# MYSQL_HOST=
# MYSQL_PORT=
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DB=
# MYSQL_SSL_MODE=
# MYSQL_CONNECT_TIMEOUT=
# MYSQL_READ_TIMEOUT=
# MYSQL_WRITE_TIMEOUT=
# DB_CONNECT_RETRIES=
# DB_RETRY_BASE_DELAY=
# DB_RETRY_MAX_DELAY=

