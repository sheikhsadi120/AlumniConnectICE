# Copy these values into backend/.env and set your real Brevo API key.
# Stable mode: Brevo API primary + SMTP fallback.

MAIL_PROVIDER=auto
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
BREVO_TIMEOUT=20

# Sender must be verified in Brevo.
SMTP_FROM_EMAIL=your-verified-sender@domain.com
SMTP_FROM_NAME=AlumniConnect Admin

# Optional SMTP fallback for resilience (used if Brevo fails for some recipients)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USERNAME=your-brevo-login-email
# SMTP_PASSWORD=your-brevo-smtp-key
